# Copy this file to .env and fill in the values for your environment.
# .env is never committed — see .gitignore.

# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-50-chars-minimum-random-string-here
# Comma-separated hostnames the app is allowed to serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# 'none' | 'optional' | 'mandatory'
ACCOUNT_EMAIL_VERIFICATION=optional

# ── Database (Docker / production) ───────────────────────────────────────────
# Leave DATABASE_URL unset to use the default SQLite database (db.sqlite3).
POSTGRES_DB=scd
POSTGRES_USER=scd
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://scd:change-me@db:5432/scd
DJANGO_SETTINGS_MODULE=scd_reporting.settings.prod
GUNICORN_WORKERS=3
SCD_HOSTNAME=scd-reporting.fnal.gov

# ── First-run admin account ───────────────────────────────────────────────────
SCD_INITIAL_ADMIN_PASSWORD=change-me

# ── AI report summaries ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Default model: claude-sonnet-4-6
# ANTHROPIC_SUMMARY_MODEL=claude-sonnet-4-6

# ── OIDC / Keycloak SSO ───────────────────────────────────────────────────────
# Set all three to enable the "Log in with SSO" button.
# OIDC_PROVIDER_URL=https://kc.apps.okddev.fnal.gov/realms/myrealm/.well-known/openid-configuration
# OIDC_CLIENT_ID=scd-report-summarizer
# OIDC_CLIENT_SECRET_FILE=/etc/scd/oidc_secret
# OIDC_CLIENT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Set both to enable the "Log in with Google" button.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Access control ────────────────────────────────────────────────────────────
# Set to 1 to block new local account sign-ups once SSO is working.
SCD_DISABLE_LOCAL_SIGNUP=0
